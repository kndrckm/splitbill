{
    "rules": {
        "sessions": {
            "$session_id": {
                ".read": true,
                "state": {
                    ".write": true
                },
                "users": {
                    "$uid": {
                        ".write": true
                    }
                },
                "updatedAt": {
                    ".write": true
                },
                "lockedBy": {
                    ".write": true
                },
                "createdAt": {
                    ".write": "!data.exists()"
                }
            }
        }
    }
}
